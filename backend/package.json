{
  "name": "backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "security:check": "npm audit",
    "security:fix": "npm audit fix",
    "db:test": "node test-db.js",
    "db:migrate": "node db/migrator.js run",
    "db:migrate:status": "node db/migrator.js status",
    "db:migrate:rollback": "node db/migrator.js rollback 1",
    "db:seed": "node db/seed.js",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "keywords": [
    "event-management",
    "express",
    "mysql",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "description": "Event Management System Backend API",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.3",
    "chartjs-node-canvas": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "express-request-id": "^3.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.1",
    "qrcode": "^1.5.4",
    "redis": "^5.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "mysql2": "^3.18.2",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2"
  }
}
